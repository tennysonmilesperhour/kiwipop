# Copy this file to .env.local and fill in real values for local development.
# In production, set these in Vercel Project Settings → Environment Variables.

# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client. Used by app/api/** route handlers only.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — get these from https://dashboard.stripe.com/apikeys
# Use pk_test_* / sk_test_* during development; pk_live_* / sk_live_* in production.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Webhook signing secret — get this when you create the webhook endpoint in Stripe.
STRIPE_WEBHOOK_SECRET=

# App
# Local: http://localhost:3000
# Vercel preview: https://$VERCEL_URL is auto-injected; set this only for production domain
NEXT_PUBLIC_SITE_URL=http://localhost:3000
